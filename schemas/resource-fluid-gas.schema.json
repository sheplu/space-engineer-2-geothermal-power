{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheplu/space-engineer-2-geothermal-power/main/schemas/resource-fluid-gas.schema.json",
  "title": "SE2 Fluid or Gas Record",
  "description": "Record shape for data/fluids.json and data/gases.json. Mirrors the base-game shape: most infobox-style numeric fields may be null when not published, and producedBy / consumedBy / storedIn close the cross-reference graph by listing the block ids that produce, consume, or store the resource.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "type",
    "mass_kg",
    "volume_liters",
    "stackable",
    "divisible",
    "description",
    "gameStatus",
    "producedBy",
    "consumedBy",
    "storedIn",
    "locations",
    "wiki",
    "dataGaps"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "displayName": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["gas", "fluid"]
    },
    "mass_kg": { "type": ["number", "null"], "minimum": 0 },
    "volume_liters": { "type": ["number", "null"], "minimum": 0 },
    "stackable": { "type": ["boolean", "null"] },
    "divisible": { "type": ["boolean", "null"] },
    "description": { "type": ["string", "null"] },
    "gameStatus": {
      "type": "string",
      "enum": ["active", "disabled", "planned"]
    },
    "producedBy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "consumedBy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "storedIn": {
      "type": "array",
      "items": { "type": "string" }
    },
    "locations": {
      "type": ["object", "null"],
      "required": ["planets", "asteroidFields"],
      "properties": {
        "planets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "biomes"],
            "properties": {
              "name": { "type": "string" },
              "biomes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "asteroidFields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "wiki": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "dataGaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
