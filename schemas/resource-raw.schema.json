{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheplu/space-engineer-2-geothermal-power/main/schemas/resource-raw.schema.json",
  "title": "SE2 Raw Resource Record",
  "description": "Record shape for entries in data/raw-resources.json — ores, stones, biogenic rocks.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "type",
    "mass_kg",
    "volume_liters",
    "stackable",
    "divisible",
    "description",
    "gameStatus",
    "locations",
    "refinableInto",
    "wiki",
    "dataGaps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "displayName": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["ore", "material"]
    },
    "mass_kg": { "type": ["number", "null"], "minimum": 0 },
    "volume_liters": { "type": ["number", "null"], "minimum": 0 },
    "stackable": { "type": "boolean" },
    "divisible": { "type": "boolean" },
    "description": { "type": ["string", "null"] },
    "gameStatus": {
      "type": "string",
      "enum": ["active", "disabled", "planned"]
    },
    "locations": {
      "type": "object",
      "required": ["planets", "asteroidFields"],
      "properties": {
        "planets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "biomes"],
            "properties": {
              "name": { "type": "string" },
              "biomes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "asteroidFields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "refinableInto": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wiki": { "type": "string", "format": "uri" },
    "dataGaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
